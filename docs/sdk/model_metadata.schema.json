    "VoiceConfig": {
      "description": "Complete voice configuration for a TTS model.\n\nThis struct describes all available voices for a TTS model, including how they are stored and which one is the default.\n\nExample: ```json { \"format\": \"embedded\", \"file\": \"voices.bin\", \"loader\": \"binary_f32_256\", \"default\": \"af_bella\", \"selection_strategy\": \"FixedIndex\", \"catalog\": [ {\"id\": \"af_bella\", \"name\": \"Bella\", \"gender\": \"female\", \"language\": \"en-US\", \"index\": 0} ] } ```",
      "type": "object",
      "oneOf": [
        {
          "description": "Voices embedded in single file (Kokoro, KittenTTS)\n\nExample: ```json { \"format\": \"embedded\", \"file\": \"voices.bin\", \"loader\": \"binary_f32_256\" } ```",
          "type": "object",
          "required": [
            "file",
            "format",
            "loader"
          ],
          "properties": {
            "file": {
              "description": "Path to voice embedding file (relative to bundle root)",
              "type": "string"
            },
            "format": {
              "type": "string",
              "enum": [
                "embedded"
              ]
            },
            "loader": {
              "description": "Loader type for parsing the file",
              "allOf": [
                {
                  "$ref": "#/definitions/VoiceLoader"
                }
              ]
            }
          }
        },
        {
          "description": "Each voice is a separate model file (Piper)\n\nExample: ```json { \"format\": \"per_model\", \"voice_dir\": \"voices/\", \"pattern\": \"{voice_id}.onnx\" } ```",
          "type": "object",
          "required": [
            "format",
            "pattern",
            "voice_dir"
          ],
          "properties": {
            "format": {
              "type": "string",
              "enum": [
                "per_model"
              ]
            },
            "pattern": {
              "description": "File pattern (e.g., \"{voice_id}.onnx\")",
              "type": "string"
            },
            "voice_dir": {
              "description": "Directory containing voice model files",
              "type": "string"
            }
          }
        },
        {
          "description": "Voice cloning from reference audio (Chatterbox, future)\n\nExample: ```json { \"format\": \"cloning\", \"encoder_model\": \"voice_encoder.onnx\", \"min_audio_seconds\": 3.0, \"max_audio_seconds\": 30.0 } ```",
          "type": "object",
          "required": [
            "encoder_model",
            "format",
            "max_audio_seconds",
            "min_audio_seconds"
          ],
          "properties": {
            "encoder_model": {
              "description": "Voice encoder model file",
              "type": "string"
            },
            "format": {
              "type": "string",
              "enum": [
                "cloning"
              ]
            },
            "max_audio_seconds": {
              "description": "Maximum reference audio duration (seconds)",
              "type": "number",
              "format": "float"
            },
            "min_audio_seconds": {
              "description": "Minimum reference audio duration (seconds)",
              "type": "number",
              "format": "float"
            }
          }
        }
      ],
      "required": [
        "catalog",
        "default"
      ],
      "properties": {
        "catalog": {
          "description": "Voice catalog with metadata",
          "type": "array",
          "items": {
            "$ref": "#/definitions/VoiceInfo"
          }
        },
        "default": {
          "description": "Default voice ID (used when no voice specified)",
          "type": "string"
        },
        "selection_strategy": {
          "description": "How voice embeddings are selected at inference time.\n\nDefaults to `FixedIndex` if not specified (backwards compatible).",
          "allOf": [
            {
              "$ref": "#/definitions/VoiceSelectionStrategy"
            }
          ]
        }
      }
    },
    "VoiceInfo": {
      "description": "Voice catalog entry with rich metadata.\n\nEach voice in a TTS model has an entry describing its properties.",
      "type": "object",
      "required": [
        "id",
        "name"
      ],
      "properties": {
        "gender": {
          "description": "Gender: \"male\", \"female\", \"neutral\"",
          "type": [
            "string",
            "null"
          ]
        },
        "id": {
          "description": "Unique identifier (used in API calls, e.g., \"af_bella\")",
          "type": "string"
        },
        "index": {
          "description": "Index in embedding file (for embedded format)",
          "type": [
            "integer",
            "null"
          ],
          "format": "uint",
          "minimum": 0.0
        },
        "language": {
          "description": "BCP-47 language tag (e.g., \"en-US\", \"ja-JP\")",
          "type": [
            "string",
            "null"
          ]
        },
        "name": {
          "description": "Human-readable display name (e.g., \"Bella\")",
          "type": "string"
        },
        "preview_url": {
          "description": "Preview audio URL (optional, for UI)",
          "type": [
            "string",
            "null"
          ]
        },
        "style": {
          "description": "Optional style descriptor (e.g., \"neutral\", \"cheerful\", \"professional\")",
          "type": [
            "string",
            "null"
          ]
        }
      }
    },
    "VoiceLoader": {
      "description": "Voice embedding loader type.\n\nSpecifies how to parse the voice embedding file.",
      "oneOf": [
        {
          "description": "Binary f32 embeddings, 256 dimensions\n\nUsed by: KittenTTS v0.1, Kokoro Format: Contiguous f32 little-endian arrays, 1024 bytes per voice",
          "type": "string",
          "enum": [
            "binary_f32_256"
          ]
        },
        {
          "description": "NumPy .npz archive\n\nUsed by: KittenTTS v0.2 Format: ZIP archive with NumPy arrays",
          "type": "string",
          "enum": [
            "numpy_npz"
          ]
        },
        {
          "description": "JSON with base64-encoded embeddings (future)",
          "type": "string",
          "enum": [
            "json_base64"
          ]
        }
      ]
    },
    "VoiceSelectionStrategy": {
      "description": "Strategy for selecting voice embeddings at inference time.\n\nDifferent TTS models use different voice selection mechanisms: - KittenTTS: Select by fixed catalog index - Kokoro: Select from voicepack by phoneme token count",
      "oneOf": [
        {
          "description": "Select voice by catalog index (default).\n\nUsed by: KittenTTS and other models with simple voice catalogs. The voice embedding is loaded at the catalog entry's fixed index.",
          "type": "string",
          "enum": [
            "FixedIndex"
          ]
        },
        {
          "description": "Select voice embedding slice by phoneme token count.\n\nUsed by: Kokoro-style voicepacks (3D arrays, shape `[510, 1, 256]`). The style vector is indexed by: `pack[min(max(token_count - 2, 0), 509)]`.",
          "type": "string",
          "enum": [
            "TokenLength"
          ]
        }
      ]
    }
  }
