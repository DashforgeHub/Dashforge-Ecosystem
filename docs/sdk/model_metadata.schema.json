{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "ModelMetadata",
  "description": "Complete model metadata describing execution strategy",
  "type": "object",
  "required": [
    "execution_template",
    "files",
    "model_id",
    "version"
  ],
  "properties": {
    "description": {
      "description": "Optional: Human-readable description",
      "default": null,
      "type": [
        "string",
        "null"
      ]
    },
    "execution_template": {
      "description": "Execution template defining how to run the model",
      "allOf": [
        {
          "$ref": "#/definitions/ExecutionTemplate"
        }
      ]
    },
    "files": {
      "description": "List of files included in the model bundle",
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "max_chunk_chars": {
      "description": "Optional: Maximum text characters per TTS chunk.\n\nOverrides the default chunking limit (350 chars) for models that need shorter sequences. Smaller models (e.g., KittenTTS nano with 15M params) produce better quality with shorter chunks (150-200 chars).",
      "type": [
        "integer",
        "null"
      ],
      "format": "uint",
      "minimum": 0.0
    },
    "metadata": {
      "description": "Optional: Additional metadata",
      "default": {},
      "type": "object",
      "additionalProperties": true
    },
    "model_id": {
      "description": "Model identifier",
      "type": "string"
    },
    "postprocessing": {
      "description": "Postprocessing steps to apply to output data",
      "default": [],
      "type": "array",
      "items": {
        "$ref": "#/definitions/PostprocessingStep"
      }
    },
    "preprocessing": {
      "description": "Preprocessing steps to apply to input data",
      "default": [],
      "type": "array",
      "items": {
        "$ref": "#/definitions/PreprocessingStep"
      }
    },
    "trim_trailing_samples": {
      "description": "Optional: Number of trailing audio samples to trim per TTS chunk.\n\nSome TTS models produce trailing artifacts at the end of each chunk. KittenTTS trims 5000 samples (~208ms at 24kHz) per chunk. Set to 0 or omit to disable trimming.",
      "type": [
        "integer",
        "null"
      ],
      "format": "uint",
      "minimum": 0.0
    },
    "version": {
      "description": "Model version",
      "type": "string"
    },
    "voices": {
      "description": "Optional: Voice configuration for TTS models",
      "anyOf": [
        {
          "$ref": "#/definitions/VoiceConfig"
        },
        {
          "type": "null"
        }
      ]
    }
  },
  "definitions": {
    "ExecutionMode": {
      "description": "Execution mode for a pipeline stage",
      "oneOf": [
        {
          "description": "Run the model once (default)",
          "type": "object",
          "required": [
            "type"
          ],
          "properties": {
            "type": {
              "type": "string",
              "enum": [
                "SingleShot"
              ]
            }
          }
        },
        {
          "description": "Run the model in an autoregressive loop",
          "type": "object",
          "required": [
            "end_token_id",
            "max_tokens",
            "start_token_id",
            "type"
          ],
          "properties": {
            "end_token_id": {
              "type": "integer",
              "format": "int64"
            },
            "max_tokens": {
              "type": "integer",
              "format": "uint",
              "minimum": 0.0
            },
            "repetition_penalty": {
              "default": 0.0,
              "type": "number",
              "format": "float"
            },
            "start_token_id": {
              "type": "integer",
              "format": "int64"
            },
            "type": {
              "type": "string",
              "enum": [
                "Autoregressive"
              ]
            }
          }
        },
        {
          "description": "Whisper-specific decoder with KV cache and forced tokens",
          "type": "object",
          "required": [
            "end_token_id",
            "language_token_id",
            "max_tokens",
            "no_timestamps_token_id",
            "start_token_id",
            "task_token_id",
            "type"
          ],
          "properties": {
            "end_token_id": {
              "type": "integer",
              "format": "int64"
            },
            "language_token_id": {
              "type": "integer",
              "format": "int64"
            },
            "max_tokens": {
              "type": "integer",
              "format": "uint",
              "minimum": 0.0
            },
            "no_timestamps_token_id": {
              "type": "integer",
              "format": "int64"
            },
            "repetition_penalty": {
              "default": 1.100000023841858,
              "type": "number",
              "format": "float"
            },
            "start_token_id": {
              "type": "integer",
              "format": "int64"
            },
            "suppress_tokens": {
              "default": [],
              "type": "array",
              "items": {
                "type": "integer",
                "format": "int64"
              }
            },
            "task_token_id": {
              "type": "integer",
              "format": "int64"
            },
            "type": {
              "type": "string",
              "enum": [
                "WhisperDecoder"
              ]
            }
          }
        },
        {
          "description": "Run the model iteratively with refinement (diffusion)",
          "type": "object",
          "required": [
            "num_steps",
            "type"
          ],
          "properties": {
            "num_steps": {
              "type": "integer",
              "format": "uint",
              "minimum": 0.0
            },
            "schedule": {
              "default": {
                "type": "Linear"
              },
              "allOf": [
                {
                  "$ref": "#/definitions/RefinementSchedule"
                }
              ]
            },
            "type": {
              "type": "string",
              "enum": [
                "IterativeRefinement"
              ]
            }
          }
        }
      ]
    },
    "ExecutionTemplate": {
      "description": "Main execution template enum - defines how a model should be executed.\n\nVariants are named by **format**, not by runtime implementation.",
      "oneOf": [
        {
          "description": "ONNX model execution via ONNX Runtime",
          "type": "object",
          "required": [
            "model_file",
            "type"
          ],
          "properties": {
            "model_file": {
              "description": "Path to the ONNX model file (relative to bundle root)",
              "type": "string"
            },
            "type": {
              "type": "string",
              "enum": [
                "Onnx"
              ]
            }
          }
        },
        {
          "description": "SafeTensors model execution via Candle runtime (pure Rust)",
          "type": "object",
          "required": [
            "model_file",
            "type"
          ],
          "properties": {
            "architecture": {
              "description": "Model architecture for routing to Rust implementation",
              "default": null,
              "type": [
                "string",
                "null"
              ]
            },
            "config_file": {
              "description": "Path to model configuration JSON",
              "default": null,
              "type": [
                "string",
                "null"
              ]
            },
            "model_file": {
              "description": "Path to the SafeTensors model file (relative to bundle root)",
              "type": "string"
            },
            "tokenizer_file": {
              "description": "Path to tokenizer JSON",
              "default": null,
              "type": [
                "string",
                "null"
              ]
            },
            "type": {
              "type": "string",
              "enum": [
                "SafeTensors"
              ]
            }
          }
        },
        {
          "description": "CoreML model execution (Apple platforms)",
          "type": "object",
          "required": [
            "model_file",
            "type"
          ],
          "properties": {
            "model_file": {
              "description": "Path to the CoreML model file",
              "type": "string"
            },
            "type": {
              "type": "string",
              "enum": [
                "CoreMl"
              ]
            }
          }
        },
        {
          "description": "TensorFlow Lite model execution (mobile)",
          "type": "object",
          "required": [
            "model_file",
            "type"
          ],
          "properties": {
            "model_file": {
              "description": "Path to the TFLite model file",
              "type": "string"
            },
            "type": {
              "type": "string",
              "enum": [
                "TfLite"
              ]
            }
          }
        },
        {
          "description": "Multi-model graph execution (DAG of models)",
          "type": "object",
          "required": [
            "stages",
            "type"
          ],
          "properties": {
            "config": {
              "description": "Model-specific configuration",
              "default": {},
              "type": "object",
              "additionalProperties": true
            },
            "stages": {
              "description": "Sequence of execution stages",
              "type": "array",
              "items": {
                "$ref": "#/definitions/PipelineStage"
              }
            },
            "type": {
              "type": "string",
              "enum": [
                "ModelGraph"
              ]
            }
          }
        },
        {
          "description": "GGUF model execution for local LLMs",
          "type": "object",
          "required": [
            "model_file",
            "type"
          ],
          "properties": {
            "chat_template": {
              "description": "Path to chat template JSON file",
              "default": null,
              "type": [
                "string",
                "null"
              ]
            },
            "context_length": {
              "description": "Maximum context length (tokens)",
              "default": 4096,
              "type": "integer",
              "format": "uint",
              "minimum": 0.0
            },
            "model_file": {
              "description": "Path to the GGUF model file",
              "type": "string"
            },
            "type": {
              "type": "string",
              "enum": [
                "Gguf"
              ]
            }
          }
        }
      ]
    },
    "InterpolationMethod": {
      "description": "Interpolation method for image resizing",
      "type": "string",
      "enum": [
        "Nearest",
        "Bilinear",
        "Bicubic"
      ]
    },
    "MelScaleType": {
      "description": "Mel frequency scale type for mel spectrogram preprocessing.\n\nDifferent models use different mel scale formulas. Using the wrong scale will produce incorrect mel spectrograms and poor model performance.",
      "oneOf": [
        {
          "description": "Slaney mel scale (used by Whisper, transformers.js, librosa default).\n\nFormula: - For freq < 1000 Hz: `mel = 3 * freq / 200` - For freq >= 1000 Hz: `mel = 15 + 27 * ln(freq / 1000) / ln(6.4)`",
          "type": "string",
          "enum": [
            "slaney"
          ]
        },
        {
          "description": "HTK mel scale (used by older implementations, mel-spec library).\n\nFormula: `mel = 2595 * log10(1 + freq / 700)`",
          "type": "string",
          "enum": [
            "htk"
          ]
        }
      ]
    },
    "PhonemizerBackend": {
      "description": "Phonemizer backend for text-to-phoneme conversion",
      "oneOf": [
        {
          "description": "Legacy. ARPABET-based. May produce lower quality for models trained on Misaki/espeak IPA.",
          "type": "string",
          "enum": [
            "CmuDictionary"
          ]
        },
        {
          "description": "Multi-language. Requires espeak-ng system installation. Install with: `brew install espeak-ng` (macOS) or `apt-get install espeak-ng` (Linux)",
          "type": "string",
          "enum": [
            "EspeakNG"
          ]
        },
        {
          "description": "Default. Pure Rust, no system dependencies. Recommended for all TTS models (Kokoro, KittenTTS). Uses bundled JSON dictionaries (us_gold.json + us_silver.json) Falls back to rule-based G2P for out-of-vocabulary words",
          "type": "string",
          "enum": [
            "MisakiDictionary"
          ]
        },
        {
          "description": "Hybrid dictionary + ONNX neural G2P fallback. No system dependencies. Uses a ~274k word dictionary for fast lookup and a small ONNX model (~59MB) for unknown words via CTC decoding. Requires `open-phonemizer.onnx` and `dictionary.json` in the model directory.",
          "type": "string",
          "enum": [
            "OpenPhonemizer"
          ]
        }
      ]
    },
    "PipelineStage": {
      "description": "A single stage in a pipeline execution",
      "type": "object",
      "required": [
        "inputs",
        "model_file",
        "name",
        "outputs"
      ],
      "properties": {
        "config": {
          "description": "Optional stage-specific configuration",
          "default": {},
          "type": "object",
          "additionalProperties": true
        },
        "execution_mode": {
          "description": "Execution mode for this stage",
          "default": {
            "type": "SingleShot"
          },
          "allOf": [
            {
              "$ref": "#/definitions/ExecutionMode"
            }
          ]
        },
        "inputs": {
          "description": "Input tensor names expected by this stage",
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "model_file": {
          "description": "Path to ONNX model file for this stage",
          "type": "string"
        },
        "name": {
          "description": "Stage name (e.g., \"encoder\", \"decoder\", \"vocoder\")",
          "type": "string"
        },
        "outputs": {
          "description": "Output tensor names produced by this stage",
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "PostprocessingStep": {
      "description": "Postprocessing step applied after model execution",
      "oneOf": [
        {
          "description": "Decode BPE tokens to text\n\nUse for: Language models, ASR models (Whisper)",
          "type": "object",
          "required": [
            "type",
            "vocab_file"
          ],
          "properties": {
            "type": {
              "type": "string",
              "enum": [
                "BPEDecode"
              ]
            },
            "vocab_file": {
              "description": "Path to vocabulary file (same as used in tokenization)",
              "type": "string"
            }
          }
        },
        {
          "description": "Apply argmax to get class index or token ID\n\nUse for: Classifiers, greedy decoding",
          "type": "object",
          "required": [
            "type"
          ],
          "properties": {
            "dim": {
              "description": "Dimension to apply argmax over (default: last dimension)",
              "default": null,
              "type": [
                "integer",
                "null"
              ],
              "format": "uint",
              "minimum": 0.0
            },
            "type": {
              "type": "string",
              "enum": [
                "Argmax"
              ]
            }
          }
        },
        {
          "description": "Apply softmax to get probabilities\n\nUse for: Classifiers, probability distributions",
          "type": "object",
          "required": [
            "type"
          ],
          "properties": {
            "dim": {
              "description": "Dimension to apply softmax over (default: last dimension)",
              "default": null,
              "type": [
                "integer",
                "null"
              ],
              "format": "uint",
              "minimum": 0.0
            },
            "type": {
              "type": "string",
              "enum": [
                "Softmax"
              ]
            }
          }
        },
        {
          "description": "Get top-K predictions with scores\n\nUse for: Multi-class classification, recommendation systems",
          "type": "object",
          "required": [
            "k",
            "type"
          ],
          "properties": {
            "dim": {
              "description": "Dimension to apply top-k over (default: last dimension)",
              "default": null,
              "type": [
                "integer",
                "null"
              ],
              "format": "uint",
              "minimum": 0.0
            },
            "k": {
              "description": "Number of top predictions to return",
              "type": "integer",
              "format": "uint",
              "minimum": 0.0
            },
            "type": {
              "type": "string",
              "enum": [
                "TopK"
              ]
            }
          }
        },
        {
          "description": "Apply threshold to convert probabilities to binary predictions\n\nUse for: Binary classification, object detection confidence filtering",
          "type": "object",
          "required": [
            "threshold",
            "type"
          ],
          "properties": {
            "return_indices": {
              "description": "Whether to return indices (true) or binary mask (false)",
              "default": false,
              "type": "boolean"
            },
            "threshold": {
              "description": "Threshold value (0.0-1.0)",
              "type": "number",
              "format": "float"
            },
            "type": {
              "type": "string",
              "enum": [
                "Threshold"
              ]
            }
          }
        },
        {
          "description": "Apply temperature sampling for token generation\n\nUse for: Creative text generation",
          "type": "object",
          "required": [
            "temperature",
            "type"
          ],
          "properties": {
            "temperature": {
              "description": "Temperature value (higher = more random, lower = more deterministic)",
              "type": "number",
              "format": "float"
            },
            "top_k": {
              "description": "Optional: Top-k filtering",
              "default": null,
              "type": [
                "integer",
                "null"
              ],
              "format": "uint",
              "minimum": 0.0
            },
            "top_p": {
              "description": "Optional: Top-p (nucleus) filtering",
              "default": null,
              "type": [
                "number",
                "null"
              ],
              "format": "float"
            },
            "type": {
              "type": "string",
              "enum": [
                "TemperatureSample"
              ]
            }
          }
        },
        {
          "description": "Denormalize tensor values (inverse of Normalize)\n\nUse for: Image generation, reversing preprocessing",
          "type": "object",
          "required": [
            "mean",
            "std",
            "type"
          ],
          "properties": {
            "mean": {
              "description": "Mean values used in normalization",
              "type": "array",
              "items": {
                "type": "number",
                "format": "float"
              }
            },
            "std": {
              "description": "Std values used in normalization",
              "type": "array",
              "items": {
                "type": "number",
                "format": "float"
              }
            },
            "type": {
              "type": "string",
              "enum": [
                "Denormalize"
              ]
            }
          }
        },
        {
          "description": "Mean pooling over token embeddings to get sentence embedding\n\nUse for: Sentence transformers (BERT, DistilBERT, all-MiniLM)",
          "type": "object",
          "required": [
            "type"
          ],
          "properties": {
            "dim": {
              "description": "Dimension to pool over (default: 1, the sequence dimension)",
              "default": 1,
              "type": "integer",
              "format": "uint",
              "minimum": 0.0
            },
            "type": {
              "type": "string",
              "enum": [
                "MeanPool"
              ]
            }
          }
        },
        {
          "description": "CTC (Connectionist Temporal Classification) decoding for ASR\n\nUse for: Wav2Vec2, Hubert, other CTC-based ASR models",
          "type": "object",
          "required": [
            "type",
            "vocab_file"
          ],
          "properties": {
            "blank_index": {
              "description": "Blank token index (usually 0)",
              "default": 0,
              "type": "integer",
              "format": "uint",
              "minimum": 0.0
            },
            "type": {
              "type": "string",
              "enum": [
                "CTCDecode"
              ]
            },
            "vocab_file": {
              "description": "Path to vocabulary file (character or word-level)",
              "type": "string"
            }
          }
        },
        {
          "description": "Convert TTS waveform output to audio bytes\n\nUse for: TTS models (KittenTTS, Piper) that output float32 waveforms",
          "type": "object",
          "required": [
            "sample_rate",
            "type"
          ],
          "properties": {
            "apply_postprocessing": {
              "description": "Whether to apply postprocessing (normalization, silence trimming)",
              "default": true,
              "type": "boolean"
            },
            "sample_rate": {
              "description": "Output sample rate in Hz",
              "type": "integer",
              "format": "uint32",
              "minimum": 0.0
            },
            "trim_trailing_silence": {
              "description": "Whether to trim trailing near-silence from the waveform (default: false)",
              "default": false,
              "type": "boolean"
            },
            "type": {
              "type": "string",
              "enum": [
                "TTSAudioEncode"
              ]
            }
          }
        },
        {
          "description": "Decode Whisper token IDs to text using HuggingFace tokenizer\n\nUse for: Whisper ASR models with HuggingFace tokenizer format",
          "type": "object",
          "required": [
            "tokenizer_file",
            "type"
          ],
          "properties": {
            "tokenizer_file": {
              "description": "Path to tokenizer.json file (HuggingFace format)",
              "type": "string"
            },
            "type": {
              "type": "string",
              "enum": [
                "WhisperDecode"
              ]
            }
          }
        }
      ]
    },
    "PreprocessingStep": {
      "description": "Preprocessing step applied before model execution",
      "oneOf": [
        {
          "description": "Convert audio to mel spectrogram\n\nUse for: ASR models (Whisper), audio classifiers\n\n# Presets\n\nInstead of specifying individual parameters, you can use a preset: ```json { \"type\": \"MelSpectrogram\", \"preset\": \"whisper\" } ```\n\nAvailable presets: `whisper`, `whisper-large`",
          "type": "object",
          "required": [
            "type"
          ],
          "properties": {
            "fft_size": {
              "description": "FFT window size (default: 400)",
              "default": 400,
              "type": "integer",
              "format": "uint",
              "minimum": 0.0
            },
            "hop_length": {
              "description": "Hop length between frames (default: 160)",
              "default": 160,
              "type": "integer",
              "format": "uint",
              "minimum": 0.0
            },
            "max_frames": {
              "description": "Maximum number of output frames (default: 3000 for 30 seconds)",
              "default": 3000,
              "type": [
                "integer",
                "null"
              ],
              "format": "uint",
              "minimum": 0.0
            },
            "mel_scale": {
              "description": "Mel frequency scale (default: Slaney)",
              "default": "slaney",
              "allOf": [
                {
                  "$ref": "#/definitions/MelScaleType"
                }
              ]
            },
            "n_mels": {
              "description": "Number of mel frequency bins (default: 80)",
              "default": 80,
              "type": "integer",
              "format": "uint",
              "minimum": 0.0
            },
            "preset": {
              "description": "Optional: Use a preset configuration (overrides other fields) Available: \"whisper\", \"whisper-large\"",
              "default": null,
              "type": [
                "string",
                "null"
              ]
            },
            "sample_rate": {
              "description": "Audio sample rate (Hz) (default: 16000)",
              "default": 16000,
              "type": "integer",
              "format": "uint32",
              "minimum": 0.0
            },
            "type": {
              "type": "string",
              "enum": [
                "MelSpectrogram"
              ]
            }
          }
        },
        {
          "description": "Tokenize text using a vocabulary file\n\nUse for: Language models, text classifiers",
          "type": "object",
          "required": [
            "tokenizer_type",
            "type",
            "vocab_file"
          ],
          "properties": {
            "max_length": {
              "description": "Optional: Maximum sequence length",
              "default": null,
              "type": [
                "integer",
                "null"
              ],
              "format": "uint",
              "minimum": 0.0
            },
            "tokenizer_type": {
              "description": "Type of tokenizer (BPE, WordPiece, SentencePiece)",
              "allOf": [
                {
                  "$ref": "#/definitions/TokenizerType"
                }
              ]
            },
            "type": {
              "type": "string",
              "enum": [
                "Tokenize"
              ]
            },
            "vocab_file": {
              "description": "Path to vocabulary file (relative to bundle root)",
              "type": "string"
            }
          }
        },
        {
          "description": "Normalize tensor values\n\nUse for: Image models (ResNet, CLIP), any model with standardized inputs",
          "type": "object",
          "required": [
            "mean",
            "std",
            "type"
          ],
          "properties": {
            "mean": {
              "description": "Mean values for normalization (per channel)",
              "type": "array",
              "items": {
                "type": "number",
                "format": "float"
              }
            },
            "std": {
              "description": "Standard deviation values (per channel)",
              "type": "array",
              "items": {
                "type": "number",
                "format": "float"
              }
            },
            "type": {
              "type": "string",
              "enum": [
                "Normalize"
              ]
            }
          }
        },
        {
          "description": "Resize image to target dimensions\n\nUse for: Image classifiers, vision models",
          "type": "object",
          "required": [
            "height",
            "type",
            "width"
          ],
          "properties": {
            "height": {
              "description": "Target height",
              "type": "integer",
              "format": "uint",
              "minimum": 0.0
            },
            "interpolation": {
              "description": "Interpolation method",
              "default": "Bilinear",
              "allOf": [
                {
                  "$ref": "#/definitions/InterpolationMethod"
                }
              ]
            },
            "type": {
              "type": "string",
              "enum": [
                "Resize"
              ]
            },
            "width": {
              "description": "Target width",
              "type": "integer",
              "format": "uint",
              "minimum": 0.0
            }
          }
        },
        {
          "description": "Center crop image to target dimensions\n\nUse for: Image classifiers (ResNet, EfficientNet) that need centered crops",
          "type": "object",
          "required": [
            "height",
            "type",
            "width"
          ],
          "properties": {
            "height": {
              "description": "Target height",
              "type": "integer",
              "format": "uint",
              "minimum": 0.0
            },
            "type": {
              "type": "string",
              "enum": [
                "CenterCrop"
              ]
            },
            "width": {
              "description": "Target width",
              "type": "integer",
              "format": "uint",
              "minimum": 0.0
            }
          }
        },
        {
          "description": "Convert audio bytes to PCM samples\n\nUse for: Audio models that need raw PCM input",
          "type": "object",
          "required": [
            "channels",
            "sample_rate",
            "type"
          ],
          "properties": {
            "channels": {
              "description": "Number of channels (1 = mono, 2 = stereo)",
              "type": "integer",
              "format": "uint",
              "minimum": 0.0
            },
            "sample_rate": {
              "description": "Target sample rate (Hz)",
              "type": "integer",
              "format": "uint32",
              "minimum": 0.0
            },
            "type": {
              "type": "string",
              "enum": [
                "AudioDecode"
              ]
            }
          }
        },
        {
          "description": "Reshape tensor to target dimensions\n\nUse for: Converting flat embeddings to multi-dimensional tensors",
          "type": "object",
          "required": [
            "shape",
            "type"
          ],
          "properties": {
            "shape": {
              "description": "Target shape (e.g., [1, 1, 28, 28] for MNIST)",
              "type": "array",
              "items": {
                "type": "integer",
                "format": "uint",
                "minimum": 0.0
              }
            },
            "type": {
              "type": "string",
              "enum": [
                "Reshape"
              ]
            }
          }
        },
        {
          "description": "Phonemize text to IPA symbols for TTS\n\nUse for: TTS models (KittenTTS, Piper, Kokoro) that require phoneme input",
          "type": "object",
          "required": [
            "tokens_file",
            "type"
          ],
          "properties": {
            "add_padding": {
              "description": "Whether to add padding tokens at start/end (default: true)",
              "default": true,
              "type": "boolean"
            },
            "backend": {
              "description": "Phonemization backend to use (default: MisakiDictionary)",
              "default": "MisakiDictionary",
              "allOf": [
                {
                  "$ref": "#/definitions/PhonemizerBackend"
                }
              ]
            },
            "dict_file": {
              "description": "Path to dictionary file (cmudict.dict for CMU, not needed for EspeakNG) If not specified, will try to load from default locations (CMU only)",
              "default": null,
              "type": [
                "string",
                "null"
              ]
            },
            "language": {
              "description": "Language code for espeak-ng (e.g., \"en-us\", \"en-gb\") Only used when backend is EspeakNG",
              "default": null,
              "type": [
                "string",
                "null"
              ]
            },
            "normalize_text": {
              "description": "Whether to normalize text before phonemization (default: false) Applies text cleanup (quotes, abbreviations, etc.) before phonemization",
              "default": false,
              "type": "boolean"
            },
            "silence_tokens": {
              "description": "Number of silence tokens to prepend before speech onset (default: None/0). Helps smooth plosive-initial words (e.g., \"b\", \"p\", \"t\" sounds). Uses token ID 30 (Kokoro silence token).",
              "default": null,
              "type": [
                "integer",
                "null"
              ],
              "format": "uint8",
              "minimum": 0.0
            },
            "tokens_file": {
              "description": "Path to tokens.txt or vocab file (maps IPA symbols to token IDs)",
              "type": "string"
            },
            "type": {
              "type": "string",
              "enum": [
                "Phonemize"
              ]
            }
          }
        }
